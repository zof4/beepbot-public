# Core domain and ports
SISTER_DOMAIN_SUFFIX=agent.example.com
CADDY_SITE_SCHEME=https
CADDY_EXTERNAL_PORT=80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CONTROL_PLANE_BIND_PORT=3001
MONITORING_BIND_PORT=3002

# Host paths
USER_DATA_ROOT_HOST=/data/users
PLATFORM_CONFIG_DIR=/opt/platform/config
PLATFORM_MONITORING_DATA_DIR=/opt/platform/monitoring/data

# User and model
DEFAULT_USER_ID=tester
CLI_USER_TOKEN=tester-app-token
AGENT_MODEL=gpt-5-codex
AGENT_DEV_OPENAI_API_KEY=

# Dispatch retries before user-facing failure
AGENT_DISPATCH_RETRY_DELAYS_MS=0,2000,6000,15000,30000

# OpenAI OAuth (per-user credential flow)
OPENAI_OAUTH_AUTHORIZATION_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_REDIRECT_URI=
OPENAI_OAUTH_SCOPES=openid profile offline_access
